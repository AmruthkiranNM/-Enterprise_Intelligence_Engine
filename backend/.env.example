# DataVex Strategic Lead Monitoring — Environment Configuration

# ── Backend ───────────────────────────────────────────────────────────────────

# API Keys
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Optional) JINA_API_KEY for deeper scraping
# JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database
# Default: sqlite:///./backend/database/leads.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/datavex

# Monitoring Schedule
# Scan interval in hours (Default: 6)
MONITOR_INTERVAL_HOURS=6

# Alert Notifications (SMTP)
# Required for High-severity email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_TO=strategy@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────

# API Base URL (Default matches vite proxy)
VITE_API_URL=http://localhost:8000
